# ─── RAGify Environment Configuration ────────────────────────────────────────
# Copy this file to .env and fill in your values.

# ─── Database (Required) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ragify:ragify_password@localhost:5432/ragify
POSTGRES_USER=ragify
POSTGRES_PASSWORD=ragify_password
POSTGRES_DB=ragify

# ─── Redis (Rate Limiting) ──────────────────────────────────────────────────
# Local Docker Redis for rate limiting
REDIS_URL=redis://localhost:6379
# Upstash Redis for query caching (optional — falls back to in-memory)
UPSTASH_REDIS_URL=

# ─── Supabase Auth (Required) ───────────────────────────────────────────────
# Get from: Supabase Dashboard → Settings → API
SUPABASE_JWT_SECRET=your-jwt-secret-here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# ─── AI Providers (At least OPENAI_API_KEY required) ────────────────────────
OPENAI_API_KEY=sk-your-openai-key
COHERE_API_KEY=              # For reranking (optional, improves quality)
GROQ_API_KEY=                # For Groq-hosted models (optional)
DEEPSEEK_API_KEY=            # For DeepSeek models (optional)
SARVAM_API_KEY=              # For Sarvam AI (optional)
ZHIPUAI_API_KEY=             # For ZhipuAI models (optional)

# ─── Observability (Optional) ───────────────────────────────────────────────
# Langfuse — LLM tracing & analytics
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── Security & CORS ────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Set to your production domain(s) when deploying:
# CORS_ALLOWED_ORIGINS=https://app.ragify.dev,https://ragify.dev

# ─── Database SSL ───────────────────────────────────────────────────────────
# Options: disable, require, verify-ca, verify-full
DB_SSL_MODE=disable

# ─── Debug Mode ─────────────────────────────────────────────────────────────
DEBUG=false

# ─── Query Planner (Optional — requires local Ollama + GPU) ────────────────
PLANNER_ENABLED=false
PLANNER_OLLAMA_URL=http://localhost:11434
PLANNER_MODEL=phi3:mini
PLANNER_TIMEOUT=3.0
PLANNER_CACHE_TTL=3600

# ─── Frontend (.env.local) ──────────────────────────────────────────────────
# These go in frontend/.env.local, NOT this file:
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# NEXT_PUBLIC_API_URL=http://localhost:8000
GEMINI_API_KEY=your-gemini-api-key
